#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/pointing.h>
#include <input/processors.dtsi>
#include <behaviors/rgbled_widget.dtsi>
#include <mouse-gesture.dtsi>

#define DEFAULT 0
#define SCROLL 1
#define RECTANGLE 2

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &bt BT_NXT  &mkp LCLK  &mo_mkp SCROLL MCLK  &mo_mkp RECTANGLE RCLK
            >;
        };

        scroll_layer {
            bindings = <
                &trans  &trans  &trans  &trans
            >;
        };

        rectangle_layer {
            bindings = <
                &trans  &trans  &trans  &trans
            >;
        };
    };

    combos {
        compatible = "zmk,combos";

        combo_bt_clear {
            bindings = <&bt BT_CLR>;
            key-positions = <0 3>;
            timeout-ms = <50>;  // default: 50
        };
    };

    behaviors {
        // Tap = mouse click (param2); hold 200ms+ = momentary layer (param1)
        mo_mkp: mo_mkp {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            bindings = <&mo>, <&mkp>;
            flavor = "tap-preferred";  // default: hold-preferred
            tapping-term-ms = <200>;
        };
    };

    // Forward/back gestures on the middle button hold
    zip_scroll_gesture: zip_scroll_gesture {
        compatible = "zmk,input-processor-mouse-gesture";
        #input-processor-cells = <0>;
        stroke-size = <100>;  // default: 200
        enable-eager-mode;
        always-active;
        gesture-cooldown-ms = <200>;  // default: 500

        forward {
            pattern = <GESTURE_LEFT>;
            bindings = <&kp LG(RBKT)>;
        };

        back {
            pattern = <GESTURE_RIGHT>;
            bindings = <&kp LG(LBKT)>;
        };
    };

    // Rectangle window-management gestures on the right button hold
    zip_rectangle_gesture: zip_rectangle_gesture {
        compatible = "zmk,input-processor-mouse-gesture";
        #input-processor-cells = <0>;
        stroke-size = <100>;  // default: 200
        enable-eager-mode;
        always-active;
        gesture-cooldown-ms = <200>;  // default: 500

        left_third {
            pattern = <GESTURE_LEFT>;
            bindings = <&kp LC(LA(D))>;
        };

        right_two_thirds {
            pattern = <GESTURE_RIGHT>;
            bindings = <&kp LC(LA(T))>;
        };

        maximize {
            pattern = <GESTURE_UP>;
            bindings = <&kp LC(LA(RET))>;
        };

        restore {
            pattern = <GESTURE_DOWN>;
            bindings = <&kp LC(LA(BSPC))>;
        };
    };
};

&trackball_listener {
    scroll {
        layers = <SCROLL>;
        input-processors = <&zip_scroll_gesture &zip_x_scaler 0 1 &zip_xy_to_scroll_mapper &zip_scroll_scaler (-1) 32>;
    };

    rectangle {
        layers = <RECTANGLE>;
        // recognize gesture first, then zero movement so the cursor stays put
        input-processors = <&zip_rectangle_gesture &zip_x_scaler 0 1 &zip_y_scaler 0 1>;
    };
};
